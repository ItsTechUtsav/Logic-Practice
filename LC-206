Problem Statement

You are given the head of a singly linked list.

Reverse the linked list and return the new head.

Example 1
Input:
head = [1,2,3,4,5]

Output:
[5,4,3,2,1]
Example 2
Input:
head = [1,2]

Output:
[2,1]
Example 3
Input:
head = []

Output:
[]




code:
#include <bits/stdc++.h>
using namespace std;

/**
 * Definition for singly-linked list.
 */
struct ListNode {
    int val;
    ListNode *next;
    ListNode(int x) : val(x), next(NULL) {}
};

class Solution {
public:
    ListNode* reverseList(ListNode* head) {

        ListNode* prev = NULL;
        ListNode* curr = head;

        while(curr != NULL) {

            ListNode* next = curr->next; // store next
            curr->next = prev;           // reverse link
            prev = curr;                // move prev
            curr = next;                // move curr
        }

        return prev;
    }
};
